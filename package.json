{
  "name": "vc-comparison-tool",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "tsx server/index.ts",
    "dev:full": "concurrently -n vite,server -c cyan,yellow \"npm run dev\" \"npm run server\"",
